{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "outDir": "dist",
        "rootDir": "src",
        "sourceMap": true,
        "declaration": false,
        "noUnusedLocals": false,
        "noUnusedParameters": false
    },
    "include": [
        "src"
    ]
}